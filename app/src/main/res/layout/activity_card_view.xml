<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2196F3"
    tools:context=".CardViewActivity">

    <RelativeLayout
        android:id="@+id/flashcard_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_back_arrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@android:color/white"
            android:contentDescription="Back"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tv_card_subject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Biology"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_toEndOf="@id/iv_back_arrow"
            android:layout_centerVertical="true"/>

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/flashcard_header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:backgroundTint="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="top">

            <TextView
                android:id="@+id/tv_card_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What is the process by which plants make their food?"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginBottom="64dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_answer_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="32dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp"
                android:visibility="visible"> <TextView
                android:id="@+id/tv_card_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Photosynthesis"
                android:textSize="20sp"
                android:textColor="@android:color/black"
                android:padding="24dp"
                android:gravity="center"
                android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_show_answer"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Show Answer"
                android:backgroundTint="#2196F3"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:layout_marginTop="32dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>