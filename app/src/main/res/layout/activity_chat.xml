<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/chatToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#2196F3"
        android:titleTextColor="@android:color/white"
        android:subtitleTextColor="#CCDDFF"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Tab toggle bar ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/tab_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/chatToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_tab_chat"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="💬 Chat"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#2196F3"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <Button
            android:id="@+id/btn_tab_resources"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📚 Resources"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="#2196F3"
            android:backgroundTint="#E3F2FD"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

    <!-- ── Universal bottom bar (shared by both tabs) ──────────────────────── -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Chat input row (visible in Chat tab) -->
        <LinearLayout
            android:id="@+id/message_input_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/et_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Type a message…"
                android:background="@drawable/rounded_edittext_background"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textSize="15sp"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="4"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_send"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="➤"
                android:textSize="18sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:backgroundTint="#2196F3"
                android:textColor="@android:color/white"
                android:padding="0dp" />

        </LinearLayout>

        <!-- Add Resource row (visible in Resources tab) -->
        <Button
            android:id="@+id/btn_add_resource"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="+ Add Resource"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:visibility="gone"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

    <!-- ── CHAT SECTION ────────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tab_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_no_messages"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No messages yet. Say hello!"
        android:textSize="15sp"
        android:textColor="#AAAAAA"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tab_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── RESOURCES SECTION (hidden until Resources tab selected) ─────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_resources"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tab_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_no_resources"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No resources yet.\nTap '+ Add Resource' to share one!"
        android:textSize="15sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tab_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
