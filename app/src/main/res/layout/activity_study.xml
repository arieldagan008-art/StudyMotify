<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/studyToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#2196F3"
        android:titleTextColor="@android:color/white"
        android:subtitleTextColor="#CCDDFF"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Card counter -->
    <TextView
        android:id="@+id/tv_study_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="1 / 5"
        android:textSize="14sp"
        android:textColor="#888888"
        app:layout_constraintTop_toBottomOf="@id/studyToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Flashcard (tap to flip) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_flashcard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tv_study_counter"
        app:layout_constraintBottom_toTopOf="@id/btn_flip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Delete card button — top-right corner -->
            <Button
                android:id="@+id/btn_delete_card"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:text="🗑"
                android:textSize="14sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:backgroundTint="#20F44336"
                android:contentDescription="Delete card" />

            <!-- Question side -->
            <LinearLayout
                android:id="@+id/layout_question_side"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="QUESTION"
                    android:textSize="10sp"
                    android:textColor="#2196F3"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tv_study_question"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Question goes here"
                    android:textSize="18sp"
                    android:textColor="#1A1A1A"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

            <!-- Answer side (hidden until flip) -->
            <LinearLayout
                android:id="@+id/layout_answer_side"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"
                android:background="#E3F2FD">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="ANSWER"
                    android:textSize="10sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tv_study_answer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Answer goes here"
                    android:textSize="18sp"
                    android:textColor="#1A237E"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Flip hint label -->
    <TextView
        android:id="@+id/tv_tap_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap card to flip"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/btn_flip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Flip button -->
    <Button
        android:id="@+id/btn_flip"
        android:layout_width="160dp"
        android:layout_height="44dp"
        android:text="Flip"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:backgroundTint="#2196F3"
        android:textColor="@android:color/white"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:layout_constraintBottom_toTopOf="@id/nav_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <!-- Prev / Next navigation row -->
    <LinearLayout
        android:id="@+id/nav_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_prev_card"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="← Prev"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:backgroundTint="#E3F2FD"
            android:textColor="#2196F3"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_next_card"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Next →"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>

    <!-- FAB: Add Card (always visible) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_study_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="Add Flashcard"
        app:srcCompat="@android:drawable/ic_input_add"
        app:backgroundTint="#2196F3"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nav_row" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_study_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No cards yet.\nTap ＋ to add your first card!"
        android:textSize="15sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/studyToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
