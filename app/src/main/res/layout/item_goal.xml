<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <!-- Horizontal wrapper: priority strip on left + content on right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Priority color strip (Green / Orange / Red) -->
        <View
            android:id="@+id/view_priority_strip"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="#4CAF50" />

        <!-- Card content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Row: checkbox + title + category badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <CheckBox
                    android:id="@+id/cb_goal_completed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:buttonTint="#2196F3" />

                <TextView
                    android:id="@+id/tv_goal_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Goal title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black" />

                <TextView
                    android:id="@+id/tv_goal_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/category_badge_background"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/tv_goal_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Description"
                android:textSize="13sp"
                android:textColor="#666666"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Due date -->
            <TextView
                android:id="@+id/tv_goal_due_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Due: DD/MM/YYYY"
                android:textSize="12sp"
                android:textColor="#999999"
                android:visibility="gone" />

            <!-- Daily smart target -->
            <TextView
                android:id="@+id/tv_daily_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Do 5 pages today to stay on track"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Progress row -->
            <LinearLayout
                android:id="@+id/layout_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_progress_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 / 50 pages"
                        android:textSize="12sp"
                        android:textColor="#555555" />

                    <Button
                        android:id="@+id/btn_log_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Log Progress"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#E3F2FD"
                        android:textColor="#1565C0"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_bar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="6dp"
                    android:progressTint="#2196F3"
                    android:progressBackgroundTint="#E0E0E0"
                    android:max="100" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
