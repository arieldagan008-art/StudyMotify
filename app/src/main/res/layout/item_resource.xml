<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="8dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Type icon -->
        <TextView
            android:id="@+id/tv_resource_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="22sp"
            android:text="📝"
            android:background="@drawable/rounded_edittext_background"
            android:layout_marginEnd="12dp" />

        <!-- Title + meta -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_resource_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resource Title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_resource_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="https://drive.google.com/..."
                android:textSize="11sp"
                android:textColor="#1565C0"
                android:maxLines="1"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <!-- Type badge -->
                <TextView
                    android:id="@+id/tv_resource_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exam"
                    android:textSize="10sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/category_badge_background"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_resource_uploader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="by Anonymous"
                    android:textSize="11sp"
                    android:textColor="#888888" />

            </LinearLayout>

        </LinearLayout>

        <!-- Open arrow -->
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="180"
            android:contentDescription="Open"
            app:tint="#CCCCCC"
            android:layout_marginStart="4dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
