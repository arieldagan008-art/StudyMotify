<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingEnd="12dp"
    android:paddingBottom="4dp"
    android:minHeight="72dp">

    <!-- ── Timeline column ─────────────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="match_parent">

        <!-- Vertical connector line (full height, centred horizontally) -->
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="#BBDEFB" />

        <!-- Time label sits at the top -->
        <TextView
            android:id="@+id/tv_slot_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="08:00"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#1565C0" />

        <!-- Dot indicator -->
        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="34dp"
            android:background="@drawable/rounded_light_blue_background" />

    </FrameLayout>

    <!-- ── Session card ─────────────────────────────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_schedule_item"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Goal name -->
            <TextView
                android:id="@+id/tv_slot_goal_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Biology"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Time range -->
            <TextView
                android:id="@+id/tv_slot_time_range"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="08:00 – 09:00"
                android:textSize="12sp"
                android:textColor="#2196F3" />

            <!-- Units + duration row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <!-- Units badge -->
                <TextView
                    android:id="@+id/tv_slot_units"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 units"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/category_badge_background"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_slot_duration"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="~45 min"
                    android:textSize="11sp"
                    android:textColor="#888888" />

                <!-- Velocity source tag -->
                <TextView
                    android:id="@+id/tv_slot_velocity_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI estimate"
                    android:textSize="10sp"
                    android:textColor="#4CAF50"
                    android:textStyle="italic" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
